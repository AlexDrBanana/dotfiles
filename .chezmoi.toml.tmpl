[diff]
    command = "delta"
    args = [
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]

{{- if eq .chezmoi.os "linux" }}
[merge]
    command = "nvim"
    args = [
        "-d",
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]
{{- else if eq .chezmoi.os "windows" }}
[merge]
    command = "pwsh"
    args = [
        "-NoProfile",
        "-Command",
        {{ printf "%q" "$base = $args[2] + '.base'; Copy-Item -LiteralPath $args[2] -Destination $base -Force; code --new-window --wait --merge $args[0] $args[2] $base $args[1]; exit $LASTEXITCODE" }},
        {{ printf "%q" "{{ .Destination }}" }},
        {{ printf "%q" "{{ .Source }}" }},
        {{ printf "%q" "{{ .Target }}" }},
    ]
{{- else }}
[merge]
    command = "bash"
    args = [
        "-c",
        {{ printf "%q" "cp {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} && code --new-window --wait --merge {{ .Destination | quote }} {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} {{ .Source | quote }}" }},
    ]
{{- end }}
